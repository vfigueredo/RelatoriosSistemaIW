	<parameter name="IDBase" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, Translation Name from ifrconstantitem where idconstant = 1168 order by name"/>
		<property name="LABEL" value="Base de Dados"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Inicio" class="java.lang.String">
		<property name="TYPE" value="#DATE"/>
		<property name="LABEL" value="Data Inicio"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Fim" class="java.lang.String">
		<property name="TYPE" value="#DATE"/>
		<property name="LABEL" value="Data Fim"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Convenio" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="LABEL" value="Convenio"/>
		<property name="SQL_COMMAND" value="select id, name from glbenterprise a  where a.HealthPlan = 1 and id not in (351) order by name"/>
		<property name="SELECTION_TYPE" value="MULTIPLE_SELECTION"/>
		<defaultValueExpression><![CDATA["255"]]></defaultValueExpression>
	</parameter>
	<parameter name="Tipo Orcamento" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="LABEL" value="Tipo Orcamento"/>
		<property name="SQL_COMMAND" value="select keyindex id, translation name from IfrConstantItem where idconstant = 1133 UNION  select &apos;100&apos; id , &apos; Todos&apos; Name order by name"/>
		<defaultValueExpression><![CDATA["100"]]></defaultValueExpression>
	</parameter>
	<parameter name="Status" class="java.lang.String">
		<property name="TYPE" value="#IWCONSTANT"/>
		<property name="LABEL" value="Status"/>
		<property name="CONSTANT_NAME" value="K_SOS_PROC_AUTORIZACAO"/>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem where idconstant = 680 and keyindex not in (0,3,4) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SET dateformat dmy;

declare @inicio datetime, @fim datetime, @idunidade int, @idbase int, @status int, @IDtipoorcamento int

set @inicio = '$P{Inicio}'
set @fim = '$P{Fim}'
set @status = $P{Status}
set @IDtipoorcamento = $P{Tipo Orcamento}
set @idunidade = $P{Unidade}
set @idbase = $P{IDBase}

select k.id IDUnidade, k.name UnidadeOp, a.*
from (
		select IDconvenio,	enterprisename, idadmission, patientname, orcamento, Protocolo, IDtipo_orcamento, Tipo_orcamento, data_inicio_orcamento, data_fim_orcamento,
				   nivel_complexidade, data_limite_envio, data_envio_pedido, data_autorizacao, StatusProrrog, diff, status, Observacao, ''Qtd, idhealthprovider,
				IDBase, Base
		from (
				Select
					 f.ID IDconvenio,	f.name enterprisename, a.idadmission, e.name patientname, max(a.id) orcamento,a.SOS_PROTOCOLO Protocolo,
					 a.sos_tipo_orcamento IDtipo_orcamento, g.translation Tipo_orcamento,
						convert(char(10),a.startdate,103) data_inicio_orcamento, convert(char(10),a.enddate,103) data_fim_orcamento,
						b.codename nivel_complexidade, convert(char(10),a.sos_dtlimiteenvio,103) data_limite_envio,
						convert(varchar,a.authorizintdate,103) data_envio_pedido, convert(varchar,a.authorizextdate,103) data_autorizacao,
						case when (datediff(day,a.authorizextdate,a.authorizintdate)) <= 0 then 'No Prazo'
							 when (datediff(day,a.authorizextdate,a.authorizintdate)) > 1 then 'Fora do Prazo'
							 when a.authorizintdate is null then 'Nao Enviado'
							 else 'Aguardando Autorizacao' end StatusProrrog,
						(datediff(day,a.authorizextdate,a.authorizintdate)) diff,
						case when a.authorizintdate is null then '1'
							 when a.authorizextdate is null then '2'
							 else '3' end status,a.Comments Observacao, ''Qtd,
					 c.idhealthprovider, 1 IDBase, 'MultiFilial' Base

				from dbiwsosvida.dbo.capbudget a (nolock) join dbiwsosvida.dbo.scccode b (nolock) on (a.sccomplexitylevel = b.id)
														  left join dbiwsosvida.dbo.capadmission c (nolock) on (a.idadmission = c.id and c.status in (1,2,5) and c.homologacao = 0)
														  join dbiwsosvida.dbo.glbpatient d (nolock) on (c.idpatient = d.id)
														  join dbiwsosvida.dbo.glbperson e (nolock) on (d.idperson = e.id)
														  join dbiwsosvida.dbo.glbenterprise f (nolock) on (c.identerprise = f.id)
														  left join dbiwsosvida.dbo.ifrconstantitem g (nolock) on (idconstant = 1133 and keyindex = a.sos_tipo_orcamento)
				where

					a.canceled = 0
					and a.startdate between @inicio+' 00:00:00' and @fim+' 23:59:59'
					and a.AuthorizExtStatus in (1)

				group by f.ID, a.SOS_PROTOCOLO, a.sos_tipo_orcamento, g.translation, f.name , a.idadmission, e.name , convert(char(10),a.startdate,103),convert(char(10),a.enddate,103),
							b.codename , a.sos_dtlimiteenvio,convert(varchar,a.authorizintdate,103),convert(varchar,a.authorizextdate,103),
							case when (datediff(day,a.authorizextdate,a.authorizintdate)) <= 0 then 'No Prazo'
								 when (datediff(day,a.authorizextdate,a.authorizintdate)) > 1 then 'Fora do Prazo'
								 when a.authorizintdate is null then 'Nao Enviado' else 'Aguardando Autorizacao' end,
							(datediff(day,a.authorizextdate,a.authorizintdate)),case when a.authorizintdate is null then '1'
								 when a.authorizextdate is null then '2'
								 else '3' end,a.Comments, c.idhealthprovider
			) aa
		where
			(aa.status = @status or @status = 0) and
			(IDtipo_orcamento = @IDtipoorcamento or @IDtipoorcamento = 100)

	UNION ALL

		select IDconvenio,	enterprisename, idadmission, patientname, orcamento, Protocolo, IDtipo_orcamento, Tipo_orcamento, data_inicio_orcamento, data_fim_orcamento,
				   nivel_complexidade, data_limite_envio, data_envio_pedido, data_autorizacao, StatusProrrog, diff, status, Observacao, ''Qtd, idhealthprovider,
				IDBase, Base
		from (
				Select
					 f.ID IDconvenio,	f.name enterprisename, a.idadmission, e.name patientname, max(a.id) orcamento,a.SOS_PROTOCOLO Protocolo,
					 a.sos_tipo_orcamento IDtipo_orcamento, g.translation Tipo_orcamento,
						convert(char(10),a.startdate,103) data_inicio_orcamento, convert(char(10),a.enddate,103) data_fim_orcamento,
						b.codename nivel_complexidade, convert(char(10),a.sos_dtlimiteenvio,103) data_limite_envio,
						convert(varchar,a.authorizintdate,103) data_envio_pedido, convert(varchar,a.authorizextdate,103) data_autorizacao,
						case when (datediff(day,a.authorizextdate,a.authorizintdate)) <= 0 then 'No Prazo'
							 when (datediff(day,a.authorizextdate,a.authorizintdate)) > 1 then 'Fora do Prazo'
							 when a.authorizintdate is null then 'Nao Enviado'
							 else 'Aguardando Autorizacao' end StatusProrrog,
						(datediff(day,a.authorizextdate,a.authorizintdate)) diff,
						case when a.authorizintdate is null then '1'
							 when a.authorizextdate is null then '2'
							 else '3' end status,a.Comments Observacao, ''Qtd,
					 6 idhealthprovider, 0 IDBase, 'Unificado' Base

				from dbiwsosvidaAracajuUnificado.dbo.capbudget a (nolock) join dbiwsosvidaAracajuUnificado.dbo.scccode b (nolock) on (a.sccomplexitylevel = b.id)
																		  join dbiwsosvidaAracajuUnificado.dbo.capadmission c (nolock) on (a.idadmission = c.id and c.status in (1,2,5) and c.homologacao = 0)
																		  join dbiwsosvidaAracajuUnificado.dbo.glbpatient d (nolock) on (c.idpatient = d.id)
																		  join dbiwsosvidaAracajuUnificado.dbo.glbperson e (nolock) on (d.idperson = e.id)
																		  join dbiwsosvidaAracajuUnificado.dbo.glbenterprise f (nolock) on (c.identerprise = f.id)
																		  left join dbiwsosvidaAracajuUnificado.dbo.ifrconstantitem g (nolock) on (idconstant = 1133 and keyindex = a.sos_tipo_orcamento)
				where

					a.canceled = 0
					and a.startdate between @inicio+' 00:00:00' and @fim+' 23:59:59'
					and a.AuthorizExtStatus in (1)

				group by f.ID, a.SOS_PROTOCOLO, a.sos_tipo_orcamento, g.translation, f.name , a.idadmission, e.name , convert(char(10),a.startdate,103),convert(char(10),a.enddate,103),
							b.codename , a.sos_dtlimiteenvio,convert(varchar,a.authorizintdate,103),convert(varchar,a.authorizextdate,103),
							case when (datediff(day,a.authorizextdate,a.authorizintdate)) <= 0 then 'No Prazo'
								 when (datediff(day,a.authorizextdate,a.authorizintdate)) > 1 then 'Fora do Prazo'
								 when a.authorizintdate is null then 'Nao Enviado' else 'Aguardando Autorizacao' end,
							(datediff(day,a.authorizextdate,a.authorizintdate)),case when a.authorizintdate is null then '1'
								 when a.authorizextdate is null then '2'
								 else '3' end,a.Comments
			) aa
		where
			(aa.status = @status or @status = 0) and
			(IDtipo_orcamento = @IDtipoorcamento or @IDtipoorcamento = 100)

	) a join glbhealthprovider k (nolock) on (k.id = a.idhealthprovider)

	where
		k.id = @idunidade
		and idconvenio in ($P{Convenio})
		and a.idbase = @idbase


order by enterprisename,StatusProrrog, patientname]]>
	</queryString>
