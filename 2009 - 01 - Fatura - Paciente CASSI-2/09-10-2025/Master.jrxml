	<field name="unitprice" class="java.lang.Double"/>
	<field name="discountitem" class="java.lang.Double"/>
	<field name="discount" class="java.lang.Double"/>
	<field name="Tipo" class="java.lang.String"/>
	<field name="Fator" class="java.lang.Double"/>
	<field name="Empresa" class="java.lang.String"/>
	<field name="Atendimento" class="java.lang.Integer"/>
	<field name="Prontuario" class="java.lang.Integer"/>
	<field name="Paciente" class="java.lang.String"/>
	<field name="Matricula" class="java.lang.String"/>
	<field name="Plano" class="java.lang.String"/>
	<field name="scdiagnostico" class="java.lang.String"/>
	<field name="diagnostico" class="java.lang.String"/>
	<field name="IDCID_Admissao" class="java.lang.String"/>
	<field name="CID_Admissao" class="java.lang.String"/>
	<field name="MotivoAlta" class="java.lang.String"/>
	<field name="Servico" class="java.lang.String"/>
	<field name="Nascimento" class="java.lang.String"/>
	<field name="InicioAtendimento" class="java.lang.String"/>
	<field name="CodTUSS" class="java.lang.String"/>
	<field name="CodTiss" class="java.lang.String"/>
	<field name="CodBrasind" class="java.lang.String"/>
	<field name="CodOPeradora" class="java.lang.String"/>
	<field name="Descricao_Map" class="java.lang.String"/>
	<field name="SCComplexityLevel" class="java.lang.Integer"/>
	<field name="TabelaDominio" class="java.lang.Short"/>
	<field name="codigo_relatorio" class="java.lang.String"/>
	<field name="Item_relatorio" class="java.lang.String"/>
	<field name="Observacao" class="java.lang.String"/>
	<field name="ValorUnitario" class="java.math.BigDecimal"/>
	<field name="Desconto" class="java.math.BigDecimal"/>
	<field name="DescontoItem" class="java.math.BigDecimal"/>
	<field name="Vlr_Cobrar" class="java.math.BigDecimal"/>
	<field name="Total" class="java.math.BigDecimal"/>
	<variable name="Total_1" class="java.lang.Double" resetType="Group" resetGroup="resourcetype" calculation="Sum">
		<variableExpression><![CDATA[$F{Vlr_Cobrar}]]></variableExpression>
	</variable>
	<variable name="Vlr_Cobrar_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{Vlr_Cobrar}]]></variableExpression>
	</variable>
	<group name="SEQ">
		<groupExpression><![CDATA[$F{seq}]]></groupExpression>
		<groupHeader>
			<band height="13">
				<textField>
					<reportElement x="1" y="0" width="553" height="13"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="true"/>
					</textElement>
					<textFieldExpression class="java.lang.String"><![CDATA[($F{resourcetype}.equals("14"))?"Dirárias Home Care":$F{Tipo}]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="19">
				<staticText>
					<reportElement x="0" y="3" width="448" height="15"/>
					<textElement textAlignment="Right" verticalAlignment="Middle" markup="none">
						<font fontName="Arial" isBold="true"/>
					</textElement>
					<text><![CDATA[Sub-Total R$:]]></text>
				</staticText>
				<textField isStretchWithOverflow="true" pattern="###0.00" isBlankWhenNull="true">
					<reportElement stretchType="RelativeToBandHeight" x="448" y="3" width="105" height="15" isPrintWhenDetailOverflows="true"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Arial" isBold="true"/>
					</textElement>
					<textFieldExpression class="java.lang.String"><![CDATA[new DecimalFormat("##,##0.00").format(new Float($V{Total_1}))]]></textFieldExpression>
				</textField>
			</band>
		</groupFooter>
	</group>
	<group name="resourcetype">
		<groupExpression><![CDATA[$F{Tipo}]]></groupExpression>
	</group>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="146" splitType="Stretch">
			<staticText>
				<reportElement x="434" y="10" width="100" height="20"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Data impressão]]></text>
			</staticText>
			<image onErrorType="Blank">
				<reportElement x="6" y="3" width="149" height="61">
					<property name="TYPE" value="#IMAGE_FROM_DATABASE"/>
				</reportElement>
				<imageExpression class="java.lang.String"><![CDATA["9527"]]></imageExpression>
			</image>
			<textField pattern="dd/MM/yyyy h.mm a">
				<reportElement x="428" y="34" width="115" height="22"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="10" isBold="false"/>
				</textElement>
				<textFieldExpression class="java.util.Date"><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="460" y="55" width="49" height="9" forecolor="#000000"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="6"/>
				</textElement>
				<text><![CDATA[Rel.2009]]></text>
			</staticText>
			<textField>
				<reportElement x="159" y="2" width="251" height="62"/>
				<textElement textAlignment="Center" verticalAlignment="Middle" markup="none">
					<font size="10" isBold="true" isStrikeThrough="false"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["\nConta Médica Domiciliar" + "\nCNPJ: 16064313/0001-43\nUnidade: "+$F{Unidade}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="0" y="69" width="555" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["<b>PACIENTE: </b>"+$F{Paciente}+"          <b>NASCIMENTO: </b>"+$F{Nascimento} +"     <b>MATRICULA: </b>"+$F{Matricula}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="171" y="108" width="31" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement textAlignment="Center" verticalAlignment="Top">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<text><![CDATA[até]]></text>
			</staticText>
			<textField>
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="202" y="108" width="70" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement textAlignment="Center" verticalAlignment="Top">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{Fim}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="0" y="109" width="111" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["<b>PERÍODO DA CONTA: </b>"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="111" y="108" width="60" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement textAlignment="Center" verticalAlignment="Top">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{Inicio}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="-1" y="82" width="555" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["<b>PLANO: </b>"+$F{Plano}+" / <b>SENHA:</b>"+$F{Senha}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="174" y="95" width="380" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement verticalAlignment="Top">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["MOTIVO DA ALTA: "+$F{MotivoAlta}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="83" y="95" width="60" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement textAlignment="Center" verticalAlignment="Top">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{InicioAtendimento}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="-1" y="95" width="84" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["<b>INTERNAÇÃO: </b>"]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement stretchType="RelativeToBandHeight" isPrintRepeatedValues="false" x="0" y="122" width="555" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement verticalAlignment="Top" markup="html">
					<font fontName="Arial" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["<b>DIAGNÓSTICO: </b> "+$F{diagnostico}+"<br><b>CID:</b> "+$F{scdiagnostico}]]></textFieldExpression>
			</textField>
		</band>
	</title>
	<columnHeader>
		<band height="32">
			<textField isStretchWithOverflow="true" isBlankWhenNull="true">
				<reportElement positionType="Float" stretchType="RelativeToBandHeight" x="1" y="0" width="555" height="13" isPrintWhenDetailOverflows="true"/>
				<textElement textAlignment="Center" markup="html">
					<font fontName="Arial" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["<b>Nro.:</b> "+$F{Atendimento}+"   <b>Número Remessa:</b> "+$F{Conta}+"   -   <b>Convênio:</b> "+$F{Empresa}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement mode="Opaque" x="73" y="17" width="280" height="15" backcolor="#CCCCCC"/>
				<textElement verticalAlignment="Middle">
