<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Pacientes por profissional" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="Atendimento" class="java.lang.String">
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="Registro_Profissional" class="java.lang.String">
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="Especialidade" class="java.lang.String">
		<property name="LABEL" value="Selecione a Especialidade"/>
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select a.ID, a.codename NAME from scccode a join capcarestaff b on (b.SCSpeciality = a.id) where  a.idtable = 144 and a.id not in (1,146167,146169,146168,151008,191802,690614,697482) union select &apos;0&apos;, &apos; Todos&apos; order by codename"/>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="LABEL" value="Unidade"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem where idconstant = 680 and keyindex not in (0,3,4) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[set dateformat dmy;

select * , b.name Unidade, '' Total
from (
		select distinct 'Multifilial' Base, a.idhealthprovider , a.id Atendimento, a.idpatient, a.identerprise, a.zonecode, a.status, a.checkindate, a.checkoutdate, a.checkoutcond, a.patientage, a.cause,
			   a.admissiontype,j.name Paciente, j.gender,  k.name enterprisepayername, g.RegistryNumber Registro, f.id IDPErsonProf, f.name professionalname, l.codename Especialidade,
			   a.AdmissionLevel , m.translation Grau_Dependencia, j.District Bairro, a.DeliveryRoute, n.translation Zona, o.name Dispensacao,
			   b.id Prescricao, c.editiontype, p.translation TipoEdicao,  c.seq, case when c.instructions is null then l.codename else c.instructions end Terapia,
			   case when c.instructions is null then 'Registro incorreto em prescrição (Terapía) ou equipe (Médico Visitador)' else d.name end Frequencia,
			   e.IDProfessional, f.name Profissional, e.scspeciality

		from dbiwsosvida.dbo.capadmission a (nolock) join dbiwsosvida.dbo.capprescription b (nolock) on (b.id in (select max(id) from dbiwsosvida.dbo.capprescription where idadmission = a.id))
													 join dbiwsosvida.dbo.capcarestaff e (nolock) on (e.idadmission = a.id and e.EndDate is null and e.ProfessionalRef = 1)
													 join dbiwsosvida.dbo.glbperson f (nolock) on (f.id = e.idprofessional)
													 join dbiwsosvida.dbo.glbprofessional g (nolock) on (g.idperson = f.id and g.scspeciality = e.scspeciality)
													 left join dbiwsosvida.dbo.GlbProfSpec gg (nolock) on (gg.IDProfessional = f.id)
													 join dbiwsosvida.dbo.glbhealthprovider h (nolock) on (a.idhealthprovider = h.id)
													 join dbiwsosvida.dbo.glbpatient i (nolock) on (a.idpatient = i.id)
													 join dbiwsosvida.dbo.glbperson j (nolock) on (i.idperson = j.id)
													 join dbiwsosvida.dbo.glbenterprise k (nolock) on (k.id = a.identerprise)
													 join dbiwsosvida.dbo.scccode l (nolock) on (g.scspeciality = l.id)
													 join dbiwsosvida.dbo.ifrconstantitem m (nolock) on (m.idconstant = 127 and m.keyindex = a.AdmissionLevel)
													 join dbiwsosvida.dbo.ifrconstantitem n (nolock) on (n.idconstant = 147 and n.keyindex = a.DeliveryRoute)
													 join dbiwsosvida.dbo.GlbHealthProvDep o (nolock) on (o.id = a.IDHealthProvDep)
													 left join dbiwsosvida.dbo.capprescripitem c (nolock) on (c.idprescription = b.id
																											   and c.seq = 24
																											   and c.editiontype in (0,1,3,4)
																											   and (g.scspeciality in ( case when c.Instructions like '%fisio%' then 11
																																	        when c.Instructions like '%Nutri%' then 16
																																	        when c.Instructions like '%Fono%' then 13
																																	        when c.Instructions like '%Enfer%' then 4
																																			when c.Instructions like '%Psic%' then 17
																																	        when c.Instructions like '%terap%ocupacional%' then 145935
																																	        when c.Instructions like '%M%dic%' then (select id
																																	        										from dbiwsosvida.dbo.scccode
																																	        										where
																																	        											idtable = 144
																																	        											and codename like '%m%dic%'
																																	        											and id =e.scspeciality
																																	        											and Leader = 1

																																											)
																																end
																															)
																													or
																												   gg.scspeciality in ( case when c.Instructions like '%fisio%' then 11
																																	        when c.Instructions like '%Nutri%' then 16
																																	        when c.Instructions like '%Fono%' then 13
																																	        when c.Instructions like '%Enfer%' then 4
																																			when c.Instructions like '%Psic%' then 17
																																	        when c.Instructions like '%terap%ocupacional%' then 145935
																																	        when c.Instructions like '%M%dic%' then (select id
																																	        										from dbiwsosvida.dbo.scccode
																																	        										where
																																	        											idtable = 144
																																	        											and codename like '%m%dic%'
																																	        											and id =e.scspeciality
																																	        											and Leader = 1

																																											)
																																end
																															)
																												)
																											 )
													 left join dbiwsosvida.dbo.glbfrequency d (nolock) on (d.id = c.IDFrequency)
													 left join dbiwsosvida.dbo.ifrconstantitem p (nolock) on (p.idconstant = 1230 and p.keyindex = c.EditionType and c.EditionType <> 1)
													 left join (select idprescription, instructions, max(id) id
																from dbiwsosvida.dbo.capprescripitem
																where
																	seq = 24
																group by idprescription, instructions
															   ) visitas on (visitas.idprescription = b.id and visitas.id =  c.id)

	) a join dbIwSOSVida.dbo.glbhealthprovider b (nolock) on (b.id = a.idhealthprovider)
where
	(convert(varchar,a.Registro) like $P{Registro_Profissional} or $P{Registro_Profissional} = 0)  and
	(a.scspeciality = $P{Especialidade} or $P{Especialidade} = 0) and
	b.id = $P{Unidade}
	and a.status = 1
	and (a.atendimento = $P{Atendimento} or $P{Atendimento} = 0)

order by Especialidade,professionalname,  tipoedicao, Paciente]]>
	</queryString>
