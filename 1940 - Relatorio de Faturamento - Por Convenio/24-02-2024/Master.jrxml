<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Resumo de Faturamento" language="groovy" pageWidth="595" pageHeight="842" whenNoDataType="NoDataSection" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Inicio" class="java.lang.String">
		<property name="LABEL" value="Data Inicial"/>
		<property name="TYPE" value="#DATE"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Fim" class="java.lang.String">
		<property name="LABEL" value="Data Fim"/>
		<property name="TYPE" value="#DATE"/>
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="Convenio" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="LABEL" value="Convenio"/>
		<property name="SQL_COMMAND" value="select id, name from glbenterprise a  where a.HealthPlan = 1 union Select 0, &apos; Todos&apos;  order by a.name  "/>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select id, name  from glbhealthprovider where id not in (2,3,4)"/>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[set dateformat dmy

declare @data_inicio as datetime, @data_fim as datetime

set @data_inicio = '$P{Inicio}'
set @data_fim = '$P{Fim}'

select h.id IDunidade, h.name Unidade, e.name Convenio, b.id, d.name Paciente, month(startdate) mes, year(startdate) ano,
	   round(sum(round(a.unitprice * a.quantity * (1 - a.discount/100) * (1 - a.discountitem/100),2)) - sum(round(a.unitprice * a.coveragequantity * (1 - a.discount/100) * (1 - a.discountitem/100),2)),2) valor_conta
from cappaymentitem a (nolock) join capadmission b (nolock) on (a.idadmission = b.id)
			join glbpatient c (nolock) on (b.idpatient = c.id)
			join glbperson d (nolock) on (c.idperson = d.id)
			join glbenterprise e (nolock) on (b.identerprise = e.id)
			join cappayment f (nolock) on (a.idpayment = f.id)
			join ifrconstantitem g (nolock) on (g.keyindex = a.resourcetype and g.idconstant = 81)
			join glbhealthprovider h (nolock) on (h.id = b.idhealthprovider)
where
  (a.idpayment in (select a.id
                   from cappayment a (nolock) left join glbenterprise b (nolock) on (b.id = a.identerprise)
                   where
						a.writeoff <> 1
						and ((
							 (a.identerprise =  $P{Convenio} or $P{Convenio} = 0)
							  and a.startdate >=  @data_inicio+' 00:00:00'
							  and a.startdate <=  @data_fim+' 23:59:59'
							  and a.liberated =  1
							  and a.simulation =  0)
						    )
					)
	)
    and h.id  = $P{Unidade}
group by e.name, year(startdate), month(startdate), b.id, d.name, h.id, h.name
order by e.name, d.name, year(startdate), month(startdate)]]>
	</queryString>
