<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Master1Sub" language="groovy" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Inicio" class="java.lang.String"/>
	<parameter name="Fim" class="java.lang.String"/>
	<parameter name="Convenio" class="java.lang.String"/>
	<parameter name="Unidade" class="java.lang.String"/>
	<queryString>
		<![CDATA[set dateformat dmy

declare @inicio as datetime, @fim as datetime

set @inicio = $P{Inicio}
set @fim = $P{Fim}

select distinct h.id IDunidade, h.name Unidade, e.name Convenio, b.id, d.name Paciente, month(startdate) mes, year(startdate) ano, i.CodeName, round(sum(round(a.unitprice * a.quantity * (1 - a.discount/100) * (1 - a.discountitem/100),2)) - sum(round(a.unitprice * a.coveragequantity * (1 - a.discount/100) * (1 - a.discountitem/100),2)),2) valor_conta, a.unitprice preco, SUM(a.quantity) quantidade


from cappaymentitem a (nolock)
            join capadmission b (nolock) on (a.idadmission = b.id)
			join glbpatient c (nolock) on (b.idpatient = c.id)
			join glbperson d (nolock) on (c.idperson = d.id)
			join glbenterprise e (nolock) on (b.identerprise = e.id)
			join cappayment f (nolock) on (a.idpayment = f.id)
			join ifrconstantitem g (nolock) on (g.keyindex = a.resourcetype and g.idconstant = 81)
			join glbhealthprovider h (nolock) on (h.id = b.idhealthprovider)
			join SccCode i on a.SCResource = i.ID
			inner join scctable j on (i.idtable = j.id) and (J.ID not in (187,198))
where
  (a.idpayment in (select a.id
                   from cappayment a (nolock) left join glbenterprise b (nolock) on (b.id = a.identerprise)
                   where
						a.writeoff <> 1
						and ((

							  (a.identerprise =  $P{Convenio} or $P{Convenio} = 0)
							  and a.startdate >=  @inicio+' 00:00:00'
							  and a.startdate <=  @fim+' 23:59:59'
							  and a.liberated =  1
							  and a.simulation =  0)
						    )
					)
	)
    and h.id  = $P{Unidade}
group by e.name, year(startdate), month(startdate), b.id, d.name, h.id, h.name, i.CodeName, UnitPrice
order by e.name, d.name, year(startdate), month(startdate)]]>
	</queryString>
	<field name="IDunidade" class="java.lang.Integer"/>
	<field name="Unidade" class="java.lang.String"/>
	<field name="Convenio" class="java.lang.String"/>
	<field name="id" class="java.lang.Integer"/>
	<field name="Paciente" class="java.lang.String"/>
	<field name="mes" class="java.lang.Integer"/>
	<field name="ano" class="java.lang.Integer"/>
	<field name="CodeName" class="java.lang.String"/>
	<field name="valor_conta" class="java.lang.Double"/>
	<field name="preco" class="java.lang.Double"/>
	<field name="quantidade" class="java.lang.Double"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<columnHeader>
		<band height="25" splitType="Stretch">
			<staticText>
				<reportElement x="16" y="3" width="100" height="20"/>
				<textElement/>
				<text><![CDATA[CodeName]]></text>
			</staticText>
			<staticText>
				<reportElement x="165" y="3" width="100" height="20"/>
				<textElement/>
				<text><![CDATA[preco]]></text>
			</staticText>
			<staticText>
				<reportElement x="265" y="3" width="100" height="20"/>
				<textElement/>
				<text><![CDATA[quantidade]]></text>
			</staticText>
			<staticText>
				<reportElement x="365" y="3" width="100" height="20"/>
				<textElement/>
				<text><![CDATA[valor_conta]]></text>
			</staticText>
		</band>
	</columnHeader>
	<detail>
		<band height="24" splitType="Stretch">
			<textField>
				<reportElement x="16" y="0" width="100" height="20"/>
				<textElement/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{CodeName}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="165" y="0" width="100" height="20"/>
				<textElement/>
				<textFieldExpression class="java.lang.Double"><![CDATA[$F{preco}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="265" y="0" width="100" height="20"/>
				<textElement/>
				<textFieldExpression class="java.lang.Double"><![CDATA[$F{quantidade}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="365" y="0" width="100" height="20"/>
				<textElement/>
				<textFieldExpression class="java.lang.Double"><![CDATA[$F{valor_conta}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
