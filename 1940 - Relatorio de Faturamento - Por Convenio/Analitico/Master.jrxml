	<field name="valor_conta" class="java.lang.Double"/>
	<field name="preco" class="java.lang.Double"/>
	<field name="quantidade" class="java.lang.Double"/>
	<variable name="valor_conta_3" class="java.lang.Double" resetType="Group" resetGroup="Paciente" calculation="Sum">
		<variableExpression><![CDATA[$F{valor_conta}]]></variableExpression>
	</variable>
	<variable name="valor_conta_2" class="java.lang.Double" resetType="Group" resetGroup="Mes" calculation="Sum">
