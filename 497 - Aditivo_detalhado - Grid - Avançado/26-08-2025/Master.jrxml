<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Rel. - 2143 - Relatório de contas geradas" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Inicio" class="java.lang.String">
		<property name="TYPE" value="#DATE"/>
		<property name="LABEL" value="Data Inicio"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Fim" class="java.lang.String">
		<property name="TYPE" value="#DATE"/>
		<property name="LABEL" value="Data Fim"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Convenio" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="LABEL" value="Convenio"/>
		<property name="SQL_COMMAND" value="select id, name from glbenterprise a  where a.HealthPlan = 1 and id not in (351) order by name"/>
		<property name="SELECTION_TYPE" value="MULTIPLE_SELECTION"/>
		<defaultValueExpression><![CDATA["263"]]></defaultValueExpression>
	</parameter>
	<parameter name="Roteiro" class="java.lang.String">
		<property name="LABEL" value="Roteiro"/>
		<property name="TYPE" value="#SQL"/>
		<property name="SELECTION_TYPE" value="MULTIPLE_SELECTION"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation NAME from ifrconstantitem where idconstant = 147 order by translation "/>
	</parameter>
	<parameter name="Status" class="java.lang.String">
		<property name="LABEL" value="Status"/>
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation NAME from ifrconstantitem where idconstant = 3 union select 10 ID, &apos; Todos&apos; Name order by translation "/>
	</parameter>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem where idconstant = 680 and keyindex not in (0,3,4) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[set dateformat dmy;

declare @inicio datetime, @fim datetime
declare @status int

set @inicio = '$P{Inicio}'
set @fim = '$P{Fim}'
set @status = $P{Status}

select row_number() over (order by j.translation, e.name,c.name, a.CreationDate,g.name) Num, a.id,  convert(varchar,a.startdate,103) Inicio, convert(varchar,a.enddate,103) Fim, e.name Profissional, b.id Atendimento, g.name Paciente, convert(varchar,a.CreationDate,103) Criacao,(case when len(convert(varchar,datepart(hh,a.CreationDate))) = 1 then  '0'+convert(varchar,datepart(hh,a.CreationDate)) else convert(varchar,datepart(hh,a.CreationDate)) end
+':'+ case when len(convert(varchar,datepart(n,a.CreationDate))) = 1 then '0'+convert(varchar,datepart(n,a.CreationDate)) else convert(varchar,datepart(n,a.CreationDate)) end+':'+ case when len(convert(varchar,datepart(s,a.CreationDate))) = 1 then '0'+convert(varchar,datepart(s,a.CreationDate)) else convert(varchar,datepart(s,a.CreationDate)) end +'.'+convert(varchar,datepart(ms,a.CreationDate))) Hora ,h.Translation Transacao, c.name Convenio,i.translation,j.translation Roteiro,b.IDHealthProvider IDunidade, l.name Unidade

from cappayment a, capadmission b, glbenterprise c, glbhistory d, glbperson e, glbpatient f, glbperson g, ifrconstantitem h,
	 ifrconstantitem i, ifrconstantitem j, glbhealthprovider l
where
	a.idadmission = b.id
	and b.identerprise in ($P{Convenio})
	and a.CreationDate between @inicio+' 00:00:00' and @fim+' 23:59:59'
	and a.simulation = 0
	and b.identerprise = c.id
	and d.id = a.id
	and d.transactiontype in (97)
	and d.transactiondate = (select min(transactiondate)
							from glbhistory gh
							where
								gh.id = d.id
								and gh.transactiontype = d.transactiontype )
	and e.id = d.IDPerson
	and f.id = b.idpatient
	and g.id = f.idperson
	and (h.idconstant = 992 and h.keyindex = d.TransactionType)
	and (i.idconstant = 3 and i.keyindex = b.status)
	and (j.idconstant = 147 and  j.keyindex = b.DeliveryRoute)
	and b.DeliveryRoute in ($P{Roteiro})
	and (b.status  = @status or @status = '10')
	and l.id = b.IDHealthProvider
	and b.IDHealthProvider = $P{Unidade}]]>
	</queryString>
