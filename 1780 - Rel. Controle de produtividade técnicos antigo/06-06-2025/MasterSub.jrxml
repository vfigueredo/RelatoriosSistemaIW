	<field name="idperson" class="java.lang.Integer"/>
	<field name="iduser" class="java.lang.String"/>
	<field name="IDPersonWriteoff" class="java.lang.Integer"/>
	<field name="description" class="java.lang.String"/>
	<field name="treatment" class="java.lang.String"/>
	<variable name="IDOcorrencias_1" class="java.lang.Integer" resetType="Group" resetGroup="Paciente" calculation="Count">
		<variableExpression><![CDATA[$F{IDOcorrencias}]]></variableExpression>
	</variable>
	<variable name="IDOcorrencias_2" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{IDOcorrencias}]]></variableExpression>
	</variable>
