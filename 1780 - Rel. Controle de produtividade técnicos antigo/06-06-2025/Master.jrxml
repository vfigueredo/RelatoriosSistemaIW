<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Master" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" isSummaryNewPage="true">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Cor">
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{Qtd_Ocorrencias}>0]]></conditionExpression>
			<style mode="Opaque" forecolor="#000000" backcolor="#CC0000"/>
		</conditionalStyle>
	</style>
	<parameter name="Programa" class="java.lang.String">
		<property name="LABEL" value="Selecione o Programa"/>
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select 0 ID, &apos; Todos&apos; Name union  select keyindex ID, translation NAME from ifrconstantitem where idconstant = 327 order by NAME"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="inicio" class="java.lang.String">
		<property name="LABEL" value="Data Inicio"/>
		<property name="TYPE" value="#DATE"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="fim" class="java.lang.String">
		<property name="LABEL" value="Data Fim"/>
		<property name="TYPE" value="#DATE"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem where idconstant = 680 and keyindex not in (0,3,4) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["Y:\\AD\\1780 - Rel. Controle de produtividade técnicos antigo\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[set dateformat dmy;

declare @inicio datetime
declare @fim datetime

set @inicio = '$P{inicio}'
set @fim = '$P{fim}'

select  k.id IDUnidade, k.name Unidade, w.name cooperativa, y.AttendanceProgram IDPrograma, z.translation Programa,
		x.Atendimento, x.Paciente, x.IDDiaria, x.ProgramaAssist, sum(x.DiasAssistencia) DiasAssistencia,
		Qtd_Ocorrencias

from (select aa.IDUnidade, Orcamento, aa.Atendimento, aa.name Paciente, aa.keyindex IDDiaria, aa.ProgramaAssist,
		        aa.DiasAssistencia,inicio, Fim
	  from (
			select b.idhealthprovider IDUnidade, a.id Orcamento, b.id Atendimento, d.name, g.keyindex,g.translation ProgramaAssist,
								case when (month(@inicio) = month(a.startdate) and year(@inicio) = year(a.startdate)) and a.startdate > @inicio then a.startdate
									 else @inicio
								end teste,
								case when (month(@inicio) = month(a.startdate) and year(@inicio) = year(a.startdate)) and a.startdate > @inicio then a.startdate
									 else @inicio
								end Inicio,

						  case when (month(@fim) = month(a.enddate) and year(@fim) = year(a.enddate)) and a.enddate < @fim then a.enddate
										 else @fim
									end fim,
						  datediff(day,case when (month(@inicio) = month(a.startdate) and year(@inicio) = year(a.startdate)) and a.startdate > @inicio then a.startdate
										 else @inicio
									end,
									case when (month(@fim) = month(a.enddate) and year(@fim) = year(a.enddate)) and a.enddate < @fim then a.enddate
										 else @fim
									end
							)+1 DiasAssistencia
			from capbudget a (nolock) join capadmission b (nolock) on (a.idadmission = b.id)
									  join glbpatient c (nolock) on (b.idpatient = c.id)
									  join glbperson d (nolock) on (c.idperson = d.id)
									  join ctrcomplexitylevel f (nolock) on (a.sccomplexitylevel = f.sccomplexitylevel)
									  join ifrconstantitem g (nolock) on (f.complexitylevel = g.keyindex and g.idconstant = 100)
			where
				(year(@inicio) = year(a.startdate) and month(@inicio) = month(a.startdate)
				or
				year(@fim) = year(a.enddate) and month(@fim) = month(a.enddate)
				)
				and b.status in (1,2)
				and b.homologacao = 0
				and a.Canceled = 0
				and a.liberated = 1
		) aa
	) x join capadmission y (nolock) on (y.id = x.Atendimento)
		join glbenterprise w (nolock) on (w.id = IDProfProvider)
		join ifrconstantitem z (nolock) on (z.idconstant = 327 and z.keyindex = y.AttendanceProgram)
		join glbhealthprovider k (nolock) on (k.id = x.IDUnidade)
		left join (select count(a.id) Qtd_Ocorrencias, a.idadmission
					from capexception a
					where
						( a.eventdate between  @inicio+' 00:00:00' and @fim+' 23:59:59'  or a.CreationDate between @inicio+' 00:00:00' and @fim+' 23:59:59' )
						and a.ExceptionType = 1710
					group by a.idadmission
				  ) Ocorrencias on (Ocorrencias.idadmission = x.atendimento)
where
	(z.keyindex = $P{Programa} or $P{Programa} = 0) and
	k.id = $P{Unidade}

group by k.id, k.name, w.name, y.AttendanceProgram, z.translation, x.Atendimento, x.Paciente, x.IDDiaria, x.ProgramaAssist, Qtd_Ocorrencias
order by w.name, z.translation, Paciente]]>
	</queryString>
