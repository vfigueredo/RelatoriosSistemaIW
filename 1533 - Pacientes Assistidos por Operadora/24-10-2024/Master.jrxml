<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Pacientes Assistidos" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="Title" fontName="Times New Roman" fontSize="50" isBold="true" pdfFontName="Times-Bold"/>
	<style name="SubTitle" forecolor="#736343" fontName="Arial" fontSize="18"/>
	<style name="Column header" forecolor="#666666" fontName="Arial" fontSize="12" isBold="true"/>
	<style name="Detail" fontName="Arial" fontSize="12"/>
	<style name="Row" mode="Transparent">
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
			<style backcolor="#E6DAC3"/>
		</conditionalStyle>
	</style>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<subDataset name="dataset1"/>
	<parameter name="CUSTOMER_LOGOTYPE_URL" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\hamilton\\Desktop\\"]]></defaultValueExpression>
	</parameter>
	<parameter name="Mes" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="LABEL" value="Mes"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation name from ifrconstantitem where idconstant = 967 order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Ano" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select distinct ANO ID, ANO NAME from td_pac_assistidos order by ANO desc"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem  where idconstant = 680 and canceled = 0 and keyindex not in (3) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[set dateformat dmy;

select 	a.ASSISTENCIA, a.PROGRAMA, a.ATENDIMENTO, a.PACIENTE, a.IDEMPRESA, a.EMPRESA, a.DATAINTERNACAO, a.DATAALTA, a.ORCAMENTO, a.INICIO, a.FIM, a.Ano, b.translation mes,
		f.id IDunidade, f.name Unidade
from td_pac_assistidos  a (nolock) join ifrconstantitem b (nolock) on (b.idconstant = 967 and b.keyindex = a.mes)
								   join capadmission c (nolock) on (c.id = a.ATENDIMENTO)
								   join glbpatient d (nolock) on (d.id = c.idpatient)
								   join glbperson e (nolock) on (e.id = d.idperson)
								   join glbhealthprovider f (nolock) on (f.id = e.idhealthprovider)
where
	ano = $P{Ano}
	and mes = $P{Mes}
	and f.id = $P{Unidade}
order by a.EMPRESA, ano ,mes, a.PACIENTE]]>
	</queryString>
	<field name="ASSISTENCIA" class="java.lang.String"/>
	<field name="PROGRAMA" class="java.lang.String"/>
	<field name="ATENDIMENTO" class="java.lang.Integer"/>
	<field name="PACIENTE" class="java.lang.String"/>
	<field name="IDEMPRESA" class="java.lang.Integer"/>
	<field name="EMPRESA" class="java.lang.String"/>
	<field name="DATAINTERNACAO" class="java.sql.Timestamp"/>
	<field name="DATAALTA" class="java.sql.Timestamp"/>
	<field name="ORCAMENTO" class="java.lang.Integer"/>
	<field name="INICIO" class="java.sql.Timestamp"/>
	<field name="FIM" class="java.sql.Timestamp"/>
	<field name="Ano" class="java.lang.Integer"/>
	<field name="mes" class="java.lang.String"/>
	<field name="IDunidade" class="java.lang.Integer"/>
	<field name="Unidade" class="java.lang.String"/>
	<variable name="qtde_1" class="java.lang.Integer" resetType="Group" resetGroup="Empresa" calculation="Sum">
		<variableExpression><![CDATA[$F{ATENDIMENTO}]]></variableExpression>
	</variable>
	<variable name="name_1" class="java.lang.Integer" resetType="Group" resetGroup="Empresa" calculation="Count">
		<variableExpression><![CDATA[$F{PACIENTE}]]></variableExpression>
	</variable>
	<group name="Empresa">
