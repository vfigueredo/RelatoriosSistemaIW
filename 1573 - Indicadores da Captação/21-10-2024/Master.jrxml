	<parameter name="CUSTOMER_LOGOTYPE_URL" class="java.lang.String" isForPrompting="false"/>
	<parameter name="Empresa" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select 0 ID, &apos; Todos&apos; Name union select distinct c.id ID , upper(c.name) NAME from td_indicadores_captacao a join capadmission b on (b.id = a.atend)           join glbenterprise c on (c.id = b.identerprise) order by name"/>
		<property name="LABEL" value="Selecione a Empresa"/>
		<defaultValueExpression><![CDATA["0"]]></defaultValueExpression>
	</parameter>
	<parameter name="mes" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select distinct mes ID, mes name from td_indicadores_captacao where len(mes) = 2 order by mes"/>
		<property name="LABEL" value="Selecione o mes"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="ano" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select distinct ano ID, ano name from td_indicadores_captacao order by ano desc"/>
		<property name="LABEL" value="Selecione o ano"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem where idconstant = 680 and keyindex not in (0,3,4) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\hamilton\\Desktop\\Escala Geral\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[declare @ano int, @mes int, @empresa int, @unidade int

set @ano = $P{ano}
set @mes = $P{mes}
set @empresa  = $P{Empresa}
set @unidade = $P{Unidade}

select distinct Row_number() over(Order by base.seq, base.indicador, a.ano, a.mes, a.paciente) Num,
		base.SEQ,
		case when e.PatientAgeyear <= 14 and base.seq = 30 then base.INDICADOR+' - Pediatria'
			 when e.PatientAgeyear > 14 and base.seq = 30 then base.INDICADOR+' - Adultos'
			 else base.INDICADOR
		end INDICADOR,
		d.id IDUNIDADE, D.NAME UnidadeOperacional
,case when A.EMPRESA is null then '--' else convert(varchar,A.EMPRESA ) end EMPRESA
,case when A.ANO is null then '--' else convert(varchar,A.ANO ) end  ANO
,case when A.MES is null then '--' else convert(varchar, A.MES) end  MES
,case when A.ATEND is null then '--' else convert(varchar,A.ATEND) end ATEND
,case when A.PACIENTE is null then '--' else convert(varchar,A.PACIENTE )  end PACIENTE
,case when A.OUTROS1 is null then '--' else convert(varchar, A.OUTROS1) end OUTROS1
,case when A.OUTROS2 is null then '--' else convert(varchar, A.OUTROS2) end OUTROS2
,case when A.OUTROS3 is null then '--' else convert(varchar, A.OUTROS3) end OUTROS3
,case when A.OUTROS4 is null then '--' else convert(varchar, A.OUTROS4) end OUTROS4
,case when A.OUTROS5 is null then '--' else convert(varchar, A.OUTROS5) end OUTROS5
,case when A.OUTROS6 is null then '--' else convert(varchar, A.OUTROS6) end OUTROS6
,case when A.OUTROS7 is null then '--' else convert(varchar, A.OUTROS7) end OUTROS7
,case when A.DATA_INICIAL is null then '--' else convert(varchar, A.DATA_INICIAL,103) end DATA_INICIAL
,case when A.DATA_FINAL is null then '--' else convert(varchar, A.DATA_FINAL,103) end DATA_FINAL
,case when C.NAME is null then '--' else convert(varchar, C.NAME) end  NAME
, case when (ANO is null and MES	is null and EMPRESA	is null and a.SEQ	is null and a.INDICADOR	is null and ATEND	is null and PACIENTE is null and
			OUTROS1	is null and OUTROS2	is null and OUTROS3	is null and OUTROS4	is null and OUTROS5	is null and OUTROS6	is null and OUTROS7	is null and
			DATA_INICIAL is null and DATA_FINAL	is null and IDUNIDADE is null
			) then 0 else 1 end Elegibibilidade
from (select distinct SEQ, INDICADOR from td_indicadores_captacao (nolock)) base left join td_indicadores_captacao a (nolock) on (a.seq = base.seq
																														          and a.indicador = base.indicador
																														          and ano = @ano
																														          and mes = @mes
																														          and a.idunidade = @unidade
																														         )
																				 left join capadmission b (nolock) on (b.id = a.atend)
																				 join glbenterprise c (nolock) on (c.id = b.identerprise and (c.id = @empresa or @empresa = '0'))
																				 left join glbhealthprovider d (nolock) on (d.id = a.idunidade or d.id = @unidade)
																				 left join CapAdmission e (nolock) on (e.id = A.ATEND and base.seq = 30)]]>
	</queryString>
