<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Master" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="NoDataSection" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Inicio" class="java.lang.String">
		<property name="LABEL" value="Data Inicio"/>
		<property name="TYPE" value="#DATE"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Fim" class="java.lang.String">
		<property name="LABEL" value="Data Fim"/>
		<property name="TYPE" value="#DATE"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem where idconstant = 680 and keyindex not in (0,3,4) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[set dateformat dmy;

declare @data_inicio datetime, @data_fim datetime
set @data_inicio = $P{Inicio}
set @data_fim  = $P{Fim}

select k.keyindex IDUnidade, k.translation UnidadeOp, a.*
from (

		select a.*, bb.data_processamento, bb.mes2, bb.ano2, bb.NumSolicatçoes
		from (Select aa.*,convert(varchar,DTLIBERACAO,103) Liberação,convert(varchar,inicioprescricao,103) Inicio,  convert(varchar,fimprescricao,103) Fim,
					convert(varchar,DATAREGISTRO,103) Registro, p.idhealthprovider
			  from relatorios.dbo.Indicador_Pend_Prod_Presc_Por_Item aa join dbiwsosvida.dbo.capprescription m (nolock) on (aa.numprescricao = m.id)
																		/* apoio para consulta unidade operacional*/
																		join dbiwsosvida.dbo.capadmission n (nolock) on (n.id = m.idadmission)
																		join dbiwsosvida.dbo.glbpatient o (nolock) on (o.id = n.idpatient)
																		join dbiwsosvida.dbo.glbperson p (nolock) on (p.id = o.idperson)
			  Where
				inicioprescricao between @data_inicio+' 00:00:00' and @data_fim+' 23:59:59'
				and not exists (select 1
							    from relatorios.dbo.Indicador_Pend_Prod_Presc_Por_Item_Cancelamentos
							    where
									idprescription = aa.numprescricao and scmaterial = aa.codscc
							   )
		) a,

		  (select convert(char(10),getdate(),103) data_processamento, month(getdate()) mes2, year(getdate()) ano2, count(*) NumSolicatçoes,
				  p.idhealthprovider idhealthprovider
		  from dbiwsosvida.dbo.matmaterialmov a left join dbiwsosvida.dbo.matmaterialtype c on (c.scmaterial = a.scmaterial)
												left join dbiwsosvida.dbo.scccode d on (d.id = a.scmaterial)
												left join dbiwsosvida.dbo.matmaterial e on (e.id = a.idmaterial)
												left join dbiwsosvida.dbo.matstoragearea f on (f.id = a.idstoareasource)
												left join dbiwsosvida.dbo.scccode g on (g.id = a.scaddresssource)
												left join dbiwsosvida.dbo.matstoragearea h on (h.id = a.idstoareadest)
												left join dbiwsosvida.dbo.scccode i on (i.id = a.scaddressdest)
												left join dbiwsosvida.dbo.capprescripitem j on (j.id = a.idprescripitem)
												left join dbiwsosvida.dbo.sccalternate l on (l.id = a.idalternate)
												join dbiwsosvida.dbo.matresupply b (nolock) on (b.id = a.idresupply)
												join dbiwsosvida.dbo.capprescription m (nolock) on (a.idprescription = m.id)
												/* apoio para consulta unidade operacional*/
												join dbiwsosvida.dbo.capadmission n (nolock) on (n.id = m.idadmission)
												join dbiwsosvida.dbo.glbpatient o (nolock) on (o.id = n.idpatient)
												join dbiwsosvida.dbo.glbperson p (nolock) on (p.id = o.idperson)

		  where
			m.id in (select id
						 from dbiwsosvida.dbo.capprescription
						 where
							--convert(char(10),getdate(),103) = convert(char(10),startdate,103)
							StartDate between @data_inicio+' 00:00:00' and @data_fim+' 23:59:59'
							and nursingliberation is not null) --Considera todas as prescrições iniciadas no dia da execução da rotina
			and datepart(dw,m.startdate) > 1 --desconsidera os domingos
			and not (b.emergency > 0 and datepart(hour,nursingliberation) >= 19) --desconsidera todas as prescrições que não sejam periódicas e que tenham sido liberadas após as 19 horas
			and not exists (select 1
							from relatorios.dbo.Indicador_Pend_Prod_Presc_Por_Item_Cancelamentos
							where
								idprescription = a.idprescription
								and scmaterial = a.scmaterial
						   )
		group by  p.idhealthprovider
		) bb

	where
		a.idhealthprovider = bb.idhealthprovider

	union all

		select a.*, bb.data_processamento, bb.mes2, bb.ano2, bb.NumSolicatçoes
		from (Select aa.*,convert(varchar,DTLIBERACAO,103) Liberação,convert(varchar,inicioprescricao,103) Inicio,  convert(varchar,fimprescricao,103) Fim,
					convert(varchar,DATAREGISTRO,103) Registro, 6 idhealthprovider
			  from relatorios.dbo.Indicador_Pend_Prod_Presc_Por_Item_AJU aa join dbiwsosvidaAracajuUnificado.dbo.capprescription m (nolock) on (aa.numprescricao = m.id)
																			/* apoio para consulta unidade operacional*/
																			join dbiwsosvidaAracajuUnificado.dbo.capadmission n (nolock) on (n.id = m.idadmission)
																			join dbiwsosvidaAracajuUnificado.dbo.glbpatient o (nolock) on (o.id = n.idpatient)
																			join dbiwsosvidaAracajuUnificado.dbo.glbperson p (nolock) on (p.id = o.idperson)
			  Where
				inicioprescricao between @data_inicio+' 00:00:00' and @data_fim+' 23:59:59'
				and not exists (select 1
							    from relatorios.dbo.Indicador_Pend_Prod_Presc_Por_Item_Cancelamentos_AJU
							    where
									idprescription = aa.numprescricao and scmaterial = aa.codscc
							   )
		) a,

		  (select convert(char(10),getdate(),103) data_processamento, month(getdate()) mes2, year(getdate()) ano2, count(*) NumSolicatçoes,
				  6 idhealthprovider
		  from dbiwsosvidaAracajuUnificado.dbo.matmaterialmov a left join dbiwsosvidaAracajuUnificado.dbo.matmaterialtype c on (c.scmaterial = a.scmaterial)
																left join dbiwsosvidaAracajuUnificado.dbo.scccode d on (d.id = a.scmaterial)
																left join dbiwsosvidaAracajuUnificado.dbo.matmaterial e on (e.id = a.idmaterial)
																left join dbiwsosvidaAracajuUnificado.dbo.matstoragearea f on (f.id = a.idstoareasource)
																left join dbiwsosvidaAracajuUnificado.dbo.scccode g on (g.id = a.scaddresssource)
																left join dbiwsosvidaAracajuUnificado.dbo.matstoragearea h on (h.id = a.idstoareadest)
																left join dbiwsosvidaAracajuUnificado.dbo.scccode i on (i.id = a.scaddressdest)
																left join dbiwsosvidaAracajuUnificado.dbo.capprescripitem j on (j.id = a.idprescripitem)
																left join dbiwsosvidaAracajuUnificado.dbo.sccalternate l on (l.id = a.idalternate)
																join dbiwsosvidaAracajuUnificado.dbo.matresupply b (nolock) on (b.id = a.idresupply)
																join dbiwsosvidaAracajuUnificado.dbo.capprescription m (nolock) on (a.idprescription = m.id)
																/* apoio para consulta unidade operacional*/
																join dbiwsosvidaAracajuUnificado.dbo.capadmission n (nolock) on (n.id = m.idadmission)
																join dbiwsosvidaAracajuUnificado.dbo.glbpatient o (nolock) on (o.id = n.idpatient)
																join dbiwsosvidaAracajuUnificado.dbo.glbperson p (nolock) on (p.id = o.idperson)

		  where
			m.id in (select id
						 from dbiwsosvidaAracajuUnificado.dbo.capprescription
						 where
							--convert(char(10),getdate(),103) = convert(char(10),startdate,103)
							StartDate between @data_inicio+' 00:00:00' and @data_fim+' 23:59:59'
							and nursingliberation is not null) --Considera todas as prescrições iniciadas no dia da execução da rotina
			and datepart(dw,m.startdate) > 1 --desconsidera os domingos
			and not (b.emergency > 0 and datepart(hour,nursingliberation) >= 19) --desconsidera todas as prescrições que não sejam periódicas e que tenham sido liberadas após as 19 horas
			and not exists (select 1
							from relatorios.dbo.Indicador_Pend_Prod_Presc_Por_Item_Cancelamentos_AJU
							where
								idprescription = a.idprescription
								and scmaterial = a.scmaterial
						   )

		) bb

	where
		a.idhealthprovider = bb.idhealthprovider

	) a join ifrconstantitem k (nolock) on (k.idconstant = 680 and k.keyindex = a.idhealthprovider)

	where
		k.keyindex = $P{Unidade}

order by NumAtendimento, NumPrescricao, CodScc]]>
	</queryString>
	<field name="IDUnidade" class="java.lang.Short"/>
	<field name="UnidadeOp" class="java.lang.String"/>
	<field name="ID" class="java.lang.Integer"/>
	<field name="NumAtendimento" class="java.lang.Integer"/>
	<field name="NumPrescricao" class="java.lang.Integer"/>
	<field name="DtLiberacao" class="java.sql.Timestamp"/>
	<field name="InicioPrescricao" class="java.sql.Timestamp"/>
	<field name="FimPrescricao" class="java.sql.Timestamp"/>
	<field name="DataRegistro" class="java.sql.Timestamp"/>
	<field name="Mes" class="java.lang.Integer"/>
	<field name="Ano" class="java.lang.Integer"/>
	<field name="CodScc" class="java.lang.Integer"/>
	<field name="Descricao" class="java.lang.String"/>
	<field name="Complementar" class="java.lang.String"/>
	<field name="Qtd" class="java.lang.Integer"/>
	<field name="Liberação" class="java.lang.String"/>
	<field name="Inicio" class="java.lang.String"/>
	<field name="Fim" class="java.lang.String"/>
	<field name="Registro" class="java.lang.String"/>
	<field name="idhealthprovider" class="java.lang.Integer"/>
	<field name="data_processamento" class="java.lang.String"/>
	<field name="mes2" class="java.lang.Integer"/>
	<field name="ano2" class="java.lang.Integer"/>
	<field name="NumSolicatçoes" class="java.lang.Integer"/>
	<variable name="ID_1" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{ID}]]></variableExpression>
	</variable>
	<variable name="Indice de pendências" class="java.lang.Float">
		<variableExpression><![CDATA[($V{ID_1}*100)/$F{NumSolicatçoes}]]></variableExpression>
	</variable>
	<group name="Atendimento">
		<groupExpression><![CDATA[$F{NumAtendimento}]]></groupExpression>
		<groupHeader>
			<band height="14">
				<textField>
					<reportElement mode="Opaque" x="0" y="0" width="802" height="14" forecolor="#CC0000" backcolor="#CCCCCC"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Arial" size="12" isBold="true"/>
					</textElement>
					<textFieldExpression class="java.lang.String"><![CDATA["Atendimento: "+$F{NumAtendimento}]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="5"/>
		</groupFooter>
	</group>
