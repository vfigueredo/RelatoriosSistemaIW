<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Indicador 1 visita de Enfermagem" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem where idconstant = 680 and keyindex not in (0,3,4) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select distinct b.idhealthprovider, k.name Unidade, a.atendimento,  d.name, a.idprescription, a.data_prescricao, a.codigo, a.Item, a.Tipo

from
	(
		select distinct i.idadmission atendimento, a.idprescription, convert(char(10),a.startdate,103) data_prescricao, o.id codigo,o.codename Item,
			   TP_Canula.idTipo idtipo, p.translation Tipo
		from dbiwsosvida.dbo.capprescripitem a (nolock) join dbiwsosvida.dbo.capprescription i (nolock) on (i.id = a.idprescription)
										join dbiwsosvida.dbo.capprescripnurse m (nolock) on (m.idprescription = i.id)
										join dbiwsosvida.dbo.scccode c (nolock) on (c.id = m.scnursingproc)
										join dbiwsosvida.dbo.capprescripmat n (nolock) on (n.idprescription = i.id)
										join dbiwsosvida.dbo.scccode o (nolock) on (o.id = n.scmaterial and o.IDTable = 56)
										join td_sos_canulas TP_Canula (nolock) on (TP_Canula.codigo = o.id)
										join IfrConstantitem p (nolock) on (p.idconstant = 873 and p.keyindex = TP_Canula.idtipo)

		where
		  a.idprescription in  (select max (b.id)
								from dbiwsosvida.dbo.capadmission a (nolock) join dbiwsosvida.dbo.capprescription b (nolock) on (a.id = b.idadmission
																																 and b.startdate >= (getdate() - 10)
																																 and a.status = 1
																																)
								group by a.id
								)
	) a join dbiwsosvida.dbo.capadmission b (nolock) on (a.atendimento = b.id
														 and b.status in ( 1,2,5 )
														 and b.HOMOLOGACAO = 0
														 and (b.canceldetail not in (0,1) or b.canceldetail is null)
														)
		join dbiwsosvida.dbo.glbpatient c (nolock) on (b.idpatient = c.id)
		join dbiwsosvida.dbo.glbperson d (nolock) on (c.idperson = d.id)
		join glbhealthprovider k (nolock) on (k.id = b.idhealthprovider)

where
		k.id = $P{Unidade}

order by tipo, name]]>
	</queryString>
	<field name="idhealthprovider" class="java.lang.Integer"/>
	<field name="Unidade" class="java.lang.String"/>
	<field name="atendimento" class="java.lang.Integer"/>
	<field name="name" class="java.lang.String"/>
	<field name="idprescription" class="java.lang.Integer"/>
	<field name="data_prescricao" class="java.lang.String"/>
	<field name="codigo" class="java.lang.Integer"/>
	<field name="Item" class="java.lang.String"/>
	<field name="Tipo" class="java.lang.String"/>
	<variable name="atendimento_1" class="java.lang.Integer" calculation="DistinctCount">
		<variableExpression><![CDATA[$F{atendimento}]]></variableExpression>
	</variable>
	<group name="Tipo">
		<groupExpression><![CDATA[$F{Tipo}]]></groupExpression>
		<groupHeader>
			<band height="36">
				<staticText>
					<reportElement x="1" y="21" width="50" height="15"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[ID]]></text>
				</staticText>
				<staticText>
					<reportElement x="50" y="21" width="306" height="15"/>
					<textElement verticalAlignment="Middle">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[Paciente]]></text>
				</staticText>
				<staticText>
					<reportElement x="356" y="21" width="100" height="15"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[Prescrição]]></text>
				</staticText>
				<staticText>
					<reportElement x="456" y="21" width="100" height="15"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[Data]]></text>
				</staticText>
				<textField>
					<reportElement mode="Opaque" x="0" y="3" width="555" height="18" backcolor="#CCFFCC"/>
					<box>
						<topPen lineWidth="0.5"/>
						<bottomPen lineWidth="0.5"/>
					</box>
					<textElement verticalAlignment="Middle">
						<font size="12" isBold="true"/>
					</textElement>
					<textFieldExpression class="java.lang.String"><![CDATA["Tipo de Canula: "+$F{Tipo}]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
	</group>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="86" splitType="Stretch">
			<rectangle>
				<reportElement x="429" y="0" width="126" height="65"/>
			</rectangle>
			<rectangle>
				<reportElement x="1" y="0" width="137" height="65"/>
			</rectangle>
			<rectangle>
				<reportElement x="138" y="0" width="291" height="65"/>
			</rectangle>
			<staticText>
				<reportElement x="140" y="0" width="289" height="65"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="16" isBold="true"/>
				</textElement>
				<text><![CDATA[Relatório de Pac. Traqueostomizados com cânula metálica/descartável]]></text>
			</staticText>
			<image onErrorType="Blank">
				<reportElement x="8" y="5" width="120" height="53">
					<property name="TYPE" value="#IMAGE_FROM_DATABASE"/>
				</reportElement>
				<imageExpression class="java.lang.String"><![CDATA["9527"]]></imageExpression>
			</image>
			<staticText>
				<reportElement x="442" y="56" width="100" height="9"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="6"/>
				</textElement>
				<text><![CDATA[Rel.1155]]></text>
			</staticText>
			<staticText>
				<reportElement x="442" y="4" width="100" height="20"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[Impresso em:]]></text>
			</staticText>
			<textField pattern="dd/MM/yyyy h.mm a">
				<reportElement x="436" y="35" width="115" height="22"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="12" isBold="false"/>
				</textElement>
				<textFieldExpression class="java.util.Date"><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="8" y="65" width="543" height="20"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="12" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["Unidade: "+$F{Unidade}]]></textFieldExpression>
			</textField>
		</band>
	</title>
	<detail>
		<band height="13" splitType="Stretch">
			<textField>
				<reportElement x="0" y="0" width="50" height="13"/>
				<box>
					<topPen lineWidth="0.5"/>
					<bottomPen lineWidth="0.5"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<textFieldExpression class="java.lang.Integer"><![CDATA[$F{atendimento}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="50" y="0" width="306" height="13"/>
				<box>
					<topPen lineWidth="0.5"/>
					<bottomPen lineWidth="0.5"/>
				</box>
				<textElement/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{name}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="356" y="0" width="100" height="13"/>
				<box>
					<topPen lineWidth="0.5"/>
					<bottomPen lineWidth="0.5"/>
				</box>
				<textElement textAlignment="Center"/>
				<textFieldExpression class="java.lang.Integer"><![CDATA[$F{idprescription}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="456" y="0" width="100" height="13"/>
				<box>
					<topPen lineWidth="0.5"/>
					<bottomPen lineWidth="0.5"/>
				</box>
				<textElement textAlignment="Center"/>
				<textFieldExpression class="java.lang.String"><![CDATA[$F{data_prescricao}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
	<pageFooter>
		<band height="15" splitType="Stretch">
			<textField isStretchWithOverflow="true">
				<reportElement stretchType="RelativeToBandHeight" x="1" y="0" width="271" height="15" isPrintWhenDetailOverflows="true"/>
				<box>
					<topPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["Página "+$V{PAGE_NUMBER}+" de "]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true" evaluationTime="Report">
				<reportElement stretchType="RelativeToBandHeight" x="272" y="0" width="284" height="15" isPrintWhenDetailOverflows="true"/>
				<box>
					<topPen lineWidth="1.0"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="8" isBold="true"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
			</textField>
		</band>
	</pageFooter>
	<summary>
		<band height="27">
