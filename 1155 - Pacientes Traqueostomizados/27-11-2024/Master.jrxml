					<text><![CDATA[Última Troca]]></text>
				</staticText>
				<textField>
					<reportElement mode="Opaque" x="0" y="3" width="555" height="18" backcolor="#CCFFCC"/>
					<box>
						<topPen lineWidth="0.5"/>
						<bottomPen lineWidth="0.5"/>
					</box>
					<textElement verticalAlignment="Middle">
						<font size="12" isBold="true"/>
					</textElement>
					<textFieldExpression class="java.lang.String"><![CDATA["Tipo de Canula: "+$F{Tipo}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement x="372" y="21" width="84" height="15"/>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[Frequência]]></text>
				</staticText>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="24">
				<textField>
					<reportElement x="455" y="10" width="100" height="14"/>
					<textElement textAlignment="Right">
						<font size="9" isBold="true"/>
					</textElement>
					<textFieldExpression class="java.lang.Integer"><![CDATA[$V{atendimento_1}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement x="1" y="10" width="121" height="14"/>
					<textElement verticalAlignment="Middle">
						<font isBold="true"/>
					</textElement>
					<text><![CDATA[Quantidade Paciente:]]></text>
				</staticText>
			</band>
		</groupFooter>
	</group>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="86" splitType="Stretch">
			<rectangle>
				<reportElement x="429" y="0" width="126" height="65"/>
