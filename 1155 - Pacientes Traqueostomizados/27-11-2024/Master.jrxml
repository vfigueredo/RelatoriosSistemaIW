<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Indicador 1 visita de Enfermagem" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.5000000000000016"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="Unidade" class="java.lang.String">
		<property name="TYPE" value="#SQL"/>
		<property name="SQL_COMMAND" value="select keyindex ID, translation Name from ifrconstantitem where idconstant = 680 and keyindex not in (0,3,4) order by name"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Inicio" class="java.lang.String">
		<property name="LABEL" value="Data Inicio"/>
		<property name="TYPE" value="#DATE"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Fim" class="java.lang.String">
		<property name="LABEL" value="Data Fim"/>
		<property name="TYPE" value="#DATE"/>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[set dateformat dmy;

declare @inicio datetime
declare @fim datetime

set @inicio = $P{Inicio}
set @fim = $P{Fim}



select CodPaciente, Paciente, CodUnidade, Unidade, FrequencyName, Tipo, CodMaterial, SCMaterialName, (select Max(II.id) from Capprescription II where (II.startdate = Max(DTPrescricao) and II.IDAdmission = CodPaciente ))  prescricao, Max(DTPrescricao) DTpresc, ultimatroca  from(

select  J.ID CodPaciente,
        (select Max(ii.startdate) from Capprescription II where (II.id = B.idprescription)) DTPrescricao,
		L.Name Paciente,
		J.idhealthprovider CodUnidade,
		N.name Unidade,
		H.Name FrequencyName,
				Case when ( select Max(m.translation) from td_sos_canulas TP_Canula, IfrConstantitem M, CapPrescripMat A  where (A.IDPrescripItem = B.ID) and (TP_Canula.codigo = a.scmaterial) and (m.idconstant = 873 and m.keyindex = TP_Canula.idtipo)) is null then ''
				     else ( select Max(m.translation) from td_sos_canulas TP_Canula, IfrConstantitem M, CapPrescripMat A  where (A.IDPrescripItem = B.ID) and (TP_Canula.codigo = a.scmaterial) and (m.idconstant = 873 and m.keyindex = TP_Canula.idtipo)) end Tipo,
				Case when ( select Max(a.SCMaterial) from td_sos_canulas TP_Canula, IfrConstantitem M, CapPrescripMat A  where (A.IDPrescripItem = B.ID) and (TP_Canula.codigo = a.scmaterial) and (m.idconstant = 873 and m.keyindex = TP_Canula.idtipo)) is null then ''
				     else CONVERT(VARCHAR,( select Max(a.SCMaterial) from td_sos_canulas TP_Canula, IfrConstantitem M, CapPrescripMat A  where (A.IDPrescripItem = B.ID) and (TP_Canula.codigo = a.scmaterial) and (m.idconstant = 873 and m.keyindex = TP_Canula.idtipo)), 7) end CodMaterial,
			   Case  when ( select Max(C.CodeName) from td_sos_canulas TP_Canula, IfrConstantitem M, CapPrescripMat A, SccCode C  where (A.IDPrescripItem = B.ID) and (TP_Canula.codigo = a.scmaterial) and (C.ID = A.SCMaterial) and (m.idconstant = 873 and m.keyindex = TP_Canula.idtipo)) is null then ''
				     else ( select Max(C.CodeName) from td_sos_canulas TP_Canula, IfrConstantitem M, CapPrescripMat A, SccCode C  where (A.IDPrescripItem = B.ID) and (TP_Canula.codigo = a.scmaterial) and (C.ID = A.SCMaterial) and (m.idconstant = 873 and m.keyindex = TP_Canula.idtipo)) end SCMaterialName,
			   case when (select MAX(AA.Ultima_troca) from  CapInfectProcedure AA, SccCode BB   where (AA.SCProcedure = BB.ID) and ( AA.IDADMISSION =   J.ID ) and AA.SCProcedure in (192380, 192378)) is null then ''
     else CONVERT(VARCHAR, (select MAX(AA.Ultima_troca) from CapInfectProcedure AA, SccCode BB   where (AA.SCProcedure = BB.ID) and ( AA.IDADMISSION =   J.ID ) and AA.SCProcedure in (192380, 192378)), 103) end  ultimatroca

from CapPrescripItem B
inner join Capprescription I (nolock) on (I.id = B.idprescription)
Inner join CapAdmission J on (I.IDAdmission = J.ID)
Inner join glbpatient K (nolock) on (J.idpatient = K.id)
Inner join glbperson L (nolock) on (K.idperson = L.id)
Inner join glbhealthprovider N (nolock) on (N.id = J.idhealthprovider)
left  join GlbFrequency H on (H.ID = B.IDFrequency)

where b.instructions like '%nula%traqueo%'
  and ( I.startdate between @inicio+' 00:00:00' and @fim+' 23:59:59')
  and N.id = $P{Unidade}

  )aa

group by CodPaciente, Paciente, CodUnidade, Unidade, FrequencyName, Tipo, CodMaterial, SCMaterialName, ultimatroca

order by TIPO, Paciente;]]>
	</queryString>
	<field name="CodPaciente" class="java.lang.Integer"/>
	<field name="Paciente" class="java.lang.String"/>
	<field name="CodUnidade" class="java.lang.Integer"/>
	<field name="Unidade" class="java.lang.String"/>
	<field name="FrequencyName" class="java.lang.String"/>
	<field name="Tipo" class="java.lang.String"/>
	<field name="CodMaterial" class="java.lang.String"/>
	<field name="SCMaterialName" class="java.lang.String"/>
	<field name="prescricao" class="java.lang.Integer"/>
	<field name="DTpresc" class="java.sql.Timestamp"/>
	<field name="ultimatroca" class="java.lang.String"/>
	<variable name="atendimento_1" class="java.lang.Integer" resetType="Group" resetGroup="Tipo" incrementType="Report" calculation="DistinctCount">
		<variableExpression><![CDATA[$F{Paciente}]]></variableExpression>
	</variable>
